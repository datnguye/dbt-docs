{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mkdocs:*)",
      "Bash(uv run dbdocs:*)",
      "Bash(uv run pre-commit:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv build:*)",
      "Bash(task:*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(lsof -i:*)",
      "Read(./**)"
    ],
    "deny": [
      "Bash(uv publish:*)",
      "Bash(twine upload:*)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-secrets.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-check.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/scripts/statusline-cost.py\""
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
